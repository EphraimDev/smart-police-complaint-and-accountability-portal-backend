# Environment
NODE_ENV=development
PORT=3000

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=complaint_portal
DB_PASSWORD=change_me_in_production
DB_NAME=complaint_portal
DB_SSL=false

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# JWT
JWT_ACCESS_SECRET=change-this-to-a-secure-random-string-min-32-chars
JWT_REFRESH_SECRET=change-this-to-another-secure-random-string-min-32-chars
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d
JWT_ISSUER=complaint-portal

# Encryption
FIELD_ENCRYPTION_KEY=must-be-exactly-32-characters-xx
PAYLOAD_ENCRYPTION_ENABLED=false
PAYLOAD_ENCRYPTION_KEY=

# Rate Limiting
RATE_LIMIT_TTL=60000
RATE_LIMIT_MAX=100
AUTH_RATE_LIMIT_TTL=60000
AUTH_RATE_LIMIT_MAX=10

# File Upload
MAX_FILE_SIZE=10485760
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/gif,application/pdf,video/mp4,audio/mpeg
UPLOAD_DEST=./uploads

# CORS
CORS_ORIGIN=http://localhost:3001

# Logging
LOG_LEVEL=debug
LOG_DIR=./logs

# Queue
QUEUE_PREFIX=complaint-portal

# AI Provider (placeholder)
AI_PROVIDER=mock
AI_API_URL=
AI_API_KEY=

# SMS Provider (placeholder)
SMS_PROVIDER=mock
SMS_API_URL=
SMS_API_KEY=

# Email Provider (placeholder)
EMAIL_PROVIDER=mock
EMAIL_FROM=noreply@complaint-portal.gov
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# Storage Provider
STORAGE_PROVIDER=local
STORAGE_BUCKET=
STORAGE_REGION=
STORAGE_ACCESS_KEY=
STORAGE_SECRET_KEY=

# Application
APP_NAME=Smart Police Complaint Portal
API_PREFIX=api/v1
SWAGGER_ENABLED=true

PAYLOAD_ENCRYPTION_ENABLED=true
PAYLOAD_ENCRYPTION_KEY=must-be-exactly-32-characters-xx
PAYLOAD_ENCRYPTION_ALGORITHM="aes-256-gcm"
GCM_IV_LENGTH=12
GCM_TAG_LENGTH=16
ENCRYPTED_PAYLOAD_SEPARATOR="."